# Copy this file to .env and fill in your values

# Option A: OpenAI (needs billing set up at platform.openai.com/account/billing)
# OPENAI_API_KEY=sk-proj-...

# Option B: Anthropic (get key at console.anthropic.com)
# ANTHROPIC_API_KEY=

# Optional: override the default model
# For OpenAI: OPENAI_MODEL=gpt-4o-mini
# For Anthropic: ANTHROPIC_MODEL=claude-haiku-4-5-20251001
